<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.PixelMarket" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Core Colors -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryContainer">@color/slate_100</item>
        <item name="colorOnPrimary">@color/white</item>
        
        <item name="colorSecondary">@color/secondary</item>
        <item name="colorOnSecondary">@color/white</item>
        
        <item name="colorSurface">@color/surface_card</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorOnSurfaceVariant">@color/text_secondary</item>
        
        <item name="android:statusBarColor">@color/status_bar</item>
        <item name="android:windowLightStatusBar">true</item>
        
        <item name="android:colorBackground">@color/background_light</item>
        <item name="android:navigationBarColor">@color/nav_bar</item>
        <item name="android:windowLightNavigationBar">true</item>

        <!-- Premium Animations -->
        <item name="android:stateListAnimator">@animator/button_click</item>
    </style>

    <style name="Theme.PixelMarket" parent="Base.Theme.PixelMarket" />

    <!-- Glassmorphism Styles -->
    <style name="GlassCard">
        <item name="android:background">@drawable/bg_glass_card</item>
        <item name="android:padding">16dp</item>
    </style>

    <style name="GlassButton" parent="Widget.Material3.Button">
        <item name="android:background">@drawable/bg_glass_card</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="backgroundTint">@null</item>
        <item name="cornerRadius">16dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="PremiumButton" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/primary</item>
        <item name="cornerRadius">16dp</item>
        <item name="android:elevation">4dp</item>
    </style>
    
    <style name="FlatTextInputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxStrokeWidth">0dp</item>
        <item name="boxStrokeWidthFocused">0dp</item>
        <item name="boxBackgroundColor">@color/glass_surface</item>
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
        <item name="android:background">@drawable/bg_glass_card</item>
        <item name="hintTextColor">@color/primary</item>
    </style>

    <style name="ShapeAppearanceOverlay.App.CornerSize50Percent" parent="">
        <item name="cornerSize">50%</item>
    </style>

    <style name="ShapeAppearanceOverlay.App.CornerSize10Percent" parent="">
        <item name="cornerSize">10%</item>
    </style>

    <!-- BottomSheet Dialog Theme for modern payment sheet -->
    <style name="BottomSheetDialogTheme" parent="Theme.Material3.Light.BottomSheetDialog">
        <item name="bottomSheetStyle">@style/CustomBottomSheet</item>
        <item name="android:windowIsFloating">false</item>
    </style>

    <style name="CustomBottomSheet" parent="Widget.Material3.BottomSheet">
        <item name="shapeAppearance">@style/BottomSheetShape</item>
        <item name="android:background">@android:color/transparent</item>
    </style>

    <style name="BottomSheetShape" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSizeTopLeft">28dp</item>
        <item name="cornerSizeTopRight">28dp</item>
        <item name="cornerSizeBottomLeft">0dp</item>
        <item name="cornerSizeBottomRight">0dp</item>
    </style>


</resources>